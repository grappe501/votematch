# Local copy: rename to `.env` or rely on VFM_DOTENV_PATH / RedDirt fallback for DATABASE_URL.
# Never commit real secrets.

DATABASE_URL=

# Optional: load another env file with override (paths relative to shell cwd, usually `petition_match/`)
VFM_DOTENV_PATH=../RedDirt/.env

# RedDirt `.env` fallback: if DATABASE_URL is still empty and VFM_DOTENV_PATH is unset, the CLI tries
# `../RedDirt/.env` then `./RedDirt/.env`. Only DATABASE_URL is read by pg; DIRECT_URL is not used.

# If the voter roll lives in a different Supabase project than RedDirt, set DATABASE_URL here and
# do not rely on RedDirt’s file.

VFM_PROJECT_KEY=sos

# Physical canonical voter table (permanent voter file; required for imports unless you only use read-only probes).
# Examples: public."VoterRecord" — if Prisma used mixed-case identifiers, match Postgres exactly (often quoted in DDL).
VFM_CANONICAL_TABLE=public.YOUR_REAL_VOTER_TABLE

# Optional: normalized view/table for candidate matching when the canonical table does not expose DOB, address, ZIP, etc.
# Point this at a view with standardized columns (see tools/voter-file-matcher/configs/match-source-standard.json
# and migrations/003_match_source_template.sql). Permanent signature rows still store the real voter_id from this source.
VFM_MATCH_SOURCE_TABLE=public.voter_match_source

VFM_HEADER_MAP_PATH=tools/voter-file-matcher/configs/sos-voter-map.json

VFM_PETITION_CODE=JACKSONVILLE_2026
VFM_PETITION_NAME=Jacksonville Petition

# Initiative metadata (also set via: npm run voter-match -- --upsert-initiative ...)
# Stored on public.petitions after migration 006: initiative_scope, reporting_geo, target_signature_count, notes

VFM_CHUNK_SIZE=500

# Optional: after applying tools/voter-file-matcher/migrations/004_import_plan_guardrails.sql, use
# npm run voter-match -- --prepare-import-plan ... --save-plan-db to persist plans in import_plans.
