# =============================================================================
# VoteMatch — local `.env` (Next.js + CLI). Copy to `.env` and edit.
# Do not commit `.env`. Do not paste real secrets into chat or docs.
# =============================================================================
#
# Local development (recommended):
#   Set VFM_DOTENV_PATH to a file that already defines DATABASE_URL, for example
#   the RedDirt app env file. Example:
#     VFM_DOTENV_PATH=../RedDirt/.env
#
# Netlify / production:
#   Do NOT set VFM_DOTENV_PATH. Set DATABASE_URL (and VFM_UPLOAD_TOKEN, VFM_*)
#   directly in Netlify → Site configuration → Environment variables.
#
# Next.js reads `petition_match/.env` for `npm run dev` / `next start`.
#
# CSV/XLSX upload and aggregate /reports do NOT require OpenAI.
#
# OCR / AI image processing — server-side only.
# Required only for JPG/PNG image ingestion (POST /api/ingest-image).
# OPENAI_API_KEY=
# OPENAI_OCR_MODEL=gpt-4o-mini
# VFM_OCR_MAX_FILE_MB=10
#
# Existing server-side upload protection (POST /api/ingest and /api/ingest-image; required in production).
# Also required in production for /review and /api/review/* (Bearer, ?token=, or votematch_operator_token cookie).
# VFM_UPLOAD_TOKEN=

VFM_DOTENV_PATH=../RedDirt/.env
VFM_PROJECT_KEY=sos
VFM_CANONICAL_TABLE=public.YOUR_REAL_VOTER_TABLE
VFM_MATCH_SOURCE_TABLE=public.voter_match_source
VFM_SOURCE_PROFILE_PATH=tools/voter-file-matcher/configs/petition-mail-list-share-v1.json
VFM_CHUNK_SIZE=500


# Optional: header map when not using VFM_SOURCE_PROFILE_PATH alone
# VFM_HEADER_MAP_PATH=tools/voter-file-matcher/configs/sos-voter-map.json

# Optional defaults for CLI imports
# VFM_PETITION_CODE=EXAMPLE_INITIATIVE_CODE
# VFM_PETITION_NAME=Example initiative display name
