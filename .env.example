# =============================================================================
# LOCAL CLI MATCHER ONLY — not used by the static Netlify landing page
# =============================================================================
#
# Copy to `.env` only on your machine when running `npm run voter-match` and
# related commands. The public site in `public/` does not read this file and
# does not need DATABASE_URL, Supabase keys, or OpenAI keys.
#
# Do not paste real secret values into Netlify environment variables for the
# static landing page. If you add serverless functions later, configure secrets
# only in the host dashboard—and only for server-side code.
#
# Never commit `.env`.

DATABASE_URL=

# Optional: load another env file (paths are relative to your shell cwd, often `petition_match/`)
VFM_DOTENV_PATH=

# If DATABASE_URL is still empty and VFM_DOTENV_PATH is unset, the CLI may try
# optional fallback paths for local monorepo layouts. Only DATABASE_URL is
# passed to pg for the matcher.

VFM_PROJECT_KEY=sos

# Canonical voter table (required for full imports unless you use read-only probes only).
VFM_CANONICAL_TABLE=public.YOUR_CANONICAL_VOTER_TABLE

# Optional: match source view/table for petition-style columns (see match-source-standard.json).
VFM_MATCH_SOURCE_TABLE=public.voter_match_source

VFM_HEADER_MAP_PATH=tools/voter-file-matcher/configs/sos-voter-map.json

VFM_PETITION_CODE=EXAMPLE_INITIATIVE_CODE
VFM_PETITION_NAME=Example initiative display name

VFM_CHUNK_SIZE=500
